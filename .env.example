# Jager AI — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenClaw / Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Binance public API base URL (no auth required)
BINANCE_BASE_URL=https://api.binance.com

# Optional: Bot admin Telegram user ID (for maintenance messages)
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
