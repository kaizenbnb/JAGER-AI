# Jager AI — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Claude model override (default: claude-3-5-haiku-20241022)
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Binance public API base URL (no auth required)
BINANCE_BASE_URL=https://api.binance.com

# Optional: path to Firebase service account JSON for persistent memory
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-adminsdk.json

# Optional: Bot admin Telegram user ID (for maintenance messages)
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
